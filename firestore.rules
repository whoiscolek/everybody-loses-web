rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function approved() {
      return signedIn() && userDoc().data.approved == true;
    }

    function admin() {
      return signedIn() && userDoc().data.isAdmin == true && userDoc().data.approved == true;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      // Prototype rule: users can update their own profile.
      // v7.1 admin unlock also writes approved/isAdmin to the current user's doc.
      // Before public deployment, move admin status to custom claims or a Cloud Function.
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        admin()
      );
      allow delete: if admin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      // Routine source refresh/finalization is performed by the Firebase Admin
      // maintenance function. Browser event writes are admin-only.
      allow create, update, delete: if admin();
    }

    match /bets/{betId} {
      allow read: if signedIn();
      allow create: if admin() || (approved() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if approved() || admin();
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if approved() || admin();
    }

    match /ledgerEntries/{entryId} {
      allow read: if signedIn() && (
        resource.data.fromUser == request.auth.uid ||
        resource.data.toUser == request.auth.uid ||
        admin()
      );
      // Server maintenance writes canonical ledger entries. Admin retains manual
      // repair access; ordinary users cannot manufacture ledger balances.
      allow create, update, delete: if admin();
    }

    match /settlements/{settlementId} {
      allow read: if signedIn() && (
        resource.data.fromUser == request.auth.uid ||
        resource.data.toUser == request.auth.uid ||
        admin()
      );
      allow create, update, delete: if admin();
    }

    match /system/{docId} {
      allow read: if signedIn();
      allow write: if admin();
    }
  }
}
