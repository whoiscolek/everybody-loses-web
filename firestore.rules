rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function approved() {
      return signedIn() && userDoc().data.approved == true;
    }

    function admin() {
      return signedIn() && userDoc().data.isAdmin == true && userDoc().data.approved == true;
    }

    function preservesProtectedAdmin() {
      return resource.data.protectedAdmin != true || (
        request.resource.data.isAdmin == true
        && request.resource.data.approved == true
        && request.resource.data.protectedAdmin == true
      );
    }

    match /users/{userId} {
      allow read: if signedIn();

      // New accounts must begin unapproved and non-admin. Privileged fields can
      // only be changed by an existing approved administrator.
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(["id", "approved", "isAdmin"])
        && request.resource.data.id == userId
        && request.resource.data.approved == false
        && request.resource.data.isAdmin == false;

      // Users may edit profile presentation/preferences only. They cannot
      // promote or approve themselves by writing directly to Firestore.
      allow update: if (admin() && preservesProtectedAdmin()) || (
        signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "email",
          "avatar",
          "profileImageUrl",
          "emailBetNotifications",
          "updatedAt"
        ])
      );
      allow delete: if admin() && resource.data.protectedAdmin != true;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      // Routine source refresh/finalization is performed by the Firebase Admin
      // maintenance function. Browser event writes are admin-only.
      allow create, update, delete: if admin();
    }

    match /bets/{betId} {
      allow read: if signedIn();
      allow create: if admin() || (
        approved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "open"
      );

      // Browser matching may move a bet between open and matched, but cannot
      // rewrite its owner, amount, event, or selection. Admin server actions
      // retain full repair/settlement authority.
      allow update: if admin() || (
        approved()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
        && resource.data.status in ["open", "matched"]
        && request.resource.data.status in ["open", "matched"]
      );
      allow delete: if admin() || (approved() && resource.data.userId == request.auth.uid);
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create: if admin() || (
        approved()
        && request.resource.data.status == "matched"
        && request.resource.data.userA != request.resource.data.userB
        && (request.resource.data.userA == request.auth.uid || request.resource.data.userB == request.auth.uid)
      );
      allow update: if admin() || (
        approved()
        && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "doubleUp",
          "amount",
          "doubleUpAmount",
          "doubledAmount",
          "doubledUp",
          "updatedAt"
        ])
      );
      allow delete: if admin() || (
        approved()
        && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid)
      );
    }

    match /ledgerEntries/{entryId} {
      allow read: if signedIn() && (
        resource.data.fromUser == request.auth.uid ||
        resource.data.toUser == request.auth.uid ||
        admin()
      );
      // Server maintenance writes canonical ledger entries. Admin retains manual
      // repair access; ordinary users cannot manufacture ledger balances.
      allow create, update, delete: if admin();
    }

    match /settlements/{settlementId} {
      allow read: if signedIn() && (
        resource.data.fromUser == request.auth.uid ||
        resource.data.toUser == request.auth.uid ||
        admin()
      );
      allow create, update, delete: if admin();
    }

    match /system/{docId} {
      allow read: if signedIn();
      allow write: if admin();
    }
  }
}
